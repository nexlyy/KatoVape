# /opt/katovape/.env — настройки БОТА на сервере. Права 600, в git НЕ коммитим.
# На сервере живёт ТОЛЬКО бот (long polling): ни nginx, ни домена, ни хостинга сайта.
# Мини-апп и админка — на GitHub Pages, сервер их не отдаёт.
PORT=8790
KV_DB=/opt/katovape/data/katovape.db

# Токен бота от @BotFather (обязателен: без него бот спит, а вход через Telegram проверяется подписью)
TELEGRAM_BOT_TOKEN=

# Режим бота: poll (по умолчанию, без домена/вебхука) | webhook
KV_BOT_MODE=poll

# Мини-приложение (на GitHub Pages) — его откроет кнопка-меню бота
MINIAPP_URL=https://nexlyy.github.io/KatoVape/demos/hub/

# Только для KV_BOT_MODE=webhook (если когда-нибудь понадобится домен):
PUBLIC_URL=
WEBHOOK_SECRET=change_me_random

# Telegram ID администраторов (через запятую). Уже включён твой id.
KV_ADMIN_IDS=5301671230

# Ассортимент из Google Sheets: URL опубликованной CSV
# (в таблице: Файл → Поделиться → Опубликовать в интернете → CSV). Можно оставить пустым.
KV_SHEETS_CSV=
