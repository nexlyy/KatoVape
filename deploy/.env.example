# /opt/katovape/.env — секреты и настройки прода. Права 600, в git НЕ коммитим.
PORT=8790
KV_DB=/opt/katovape/data/katovape.db

# Токен бота от @BotFather (обязательно для прода: включает проверку подписи Telegram)
TELEGRAM_BOT_TOKEN=

# Публичный https-адрес ЭТОГО API (за nginx). Вебхук будет PUBLIC_URL + /tg/webhook/<secret>
# Пример: https://shop.mcrplanet.com/api
PUBLIC_URL=

# Адрес мини-приложения, который откроет кнопка-меню бота
# Пример: https://shop.mcrplanet.com/demos/hub/
MINIAPP_URL=

# Секрет пути вебхука (любая строка). Тот же секрет Telegram шлёт в заголовке.
WEBHOOK_SECRET=change_me_random

# Telegram ID администраторов (через запятую). Уже включён твой id.
KV_ADMIN_IDS=5301671230

# Ассортимент из Google Sheets: URL опубликованной CSV
# (в таблице: Файл → Поделиться → Опубликовать в интернете → CSV). Можно оставить пустым.
KV_SHEETS_CSV=
